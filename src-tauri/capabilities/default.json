{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "core:event:default",
    {
      "identifier": "core:event:allow-listen",
      "allow": [
        { "event": "query-chunk" },
        { "event": "query-complete" },
        { "event": "tauri://drag-drop" }
      ]
    }
  ]
}
